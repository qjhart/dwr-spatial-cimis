#!/usr/bin/env bash

############################################################################
#
# MODULE:       g.cimis.symsoft_test
# AUTHOR(S):    Quinn Hart
# PURPOSE:      Calculate raster comparison statistics for Symsoft ETo against CIMIS ETo
# COPYRIGHT:    (C) 2024 by Quinn Hart
