#############################################################################
# Change to 3 for working
export GRASS_VERBOSE=5

#%Module
#%  description: Calculate raster comparison statistics for Symsoft ETo against CIMIS ETo
#%  keywords: CIMIS evapotranspiration
#%End
#%flag
#% key: f
#% description: force commands to be run regardless if files exist
#% guisection: Main
#%end
#%flag
#% key: e
#% description: Calculate 28day RMS error
#% guisection: Main
#%end

function G_verify_mapset() {
  if [[ ! ${GBL[MAPSET]} =~ ^20[012][0-9][01][0-9][0-3][0-9]_s$ ]]; then
    g.message -e message="Mapset ${GBL[MAPSET]} not valid symsoft mapset"
    exit 1
  fi
}

function diff() {
  local m=$1
  local d=${GBL[YYYYMMDD]}_d
  local n=${GBL[YYYYMMDD]}
  g.message -v message="r.mapcalc ${GBL[overwrite]} --quiet expression=\"${m}_d_diff=${m}-'${m}@$d'\"";
  g.message -v message="r.mapcalc ${GBL[overwrite]} --quiet expression=\"${m}_q_diff='${m}-${m}@$n'\"";
  r.mapcalc ${GBL[overwrite]} --quiet expression="${m}_d_diff=${m}-'${m}@$d'";
#  r.mapcalc ${GBL[overwrite]} --quiet expression="${m}_q_diff=${m}-'${m}@$n'";
}

function stats_make() {
  local date="${GBL[YYYY]}-${GBL[MM]}-${GBL[DD]}"
  local doy=$(date -d "${date}" +%j)
  g.copy vect=dau@PERMANENT,stats --overwrite
  v.db.addcolumn map=stats columns='date date,doy integer'
  v.db.update map=stats column=date value="${date}"
  v.db.update map=stats column=doy value="${doy}"
}


function stats_add() {
  local m=$1
  local d=${GBL[YYYYMMDD]}_d
  local n=${GBL[YYYYMMDD]}
  # First Add in reference stats
  v.rast.stats -c map=stats raster=${m}@$d column_prefix=$m method=average,stddev -c
  # Then add in change
  v.rast.stats -c map=stats raster=${m}_d_diff column_prefix=${m}_d_diff method=average,stddev
}


# Get the last 28 days for the matching filename.  Add up all the errors
function rmse28() {
  local B=$1
  local prev=
  local d=0
  local RMSE=
  for t in d q; do
    RMSE=${b}_${t}_rmse28
    for i in $(seq -27 0); do
      m=$(date --date="${GBL[YYYYMMDD]} + $i days" +%Y%m%d);
      #g.message -d debug=$DEBUG message="r.info $B@$m"
      if (r.info -r map="${B}_${t}_diff@$m" > /dev/null 2>&1); then
        prev+="'(${B}_${t}_diff@$m)^2'+"
        let d+=1
        #g.message -d debug=$DEBUG message="found ${B}_${t}_rms@$m, prev=$prev"
      fi
    done
    prev=${prev:0:-1}
    local cmd="r.mapcalc  --quiet --overwrite expression=\"${RMSE}=sqrt(($prev)/$d)\""
    g.message -d debug=$DEBUG message="$cmd"
    r.mapcalc  --quiet --overwrite expression="${RMSE}=sqrt(($prev)/$d)"
    echo "'${RMSE}@${GBL[YYYYMMDD]}'"
  done
}


## MAIN Program
if  [ -z "$GISBASE" ] ; then
    echo "You must be in GRASS GIS to run this program."
    exit 1
fi

# save command line
if [ "$1" != "@ARGS_PARSED@" ] ; then
    exec g.parser "$0" "$@"
fi

# CIMIS uses YYYYMMDD for all standard mapsets
# Global variables
eval $(g.gisenv)
declare -g -A GBL
GBL[GISDBASE]=$GISDBASE
GBL[LOCATION_NAME]=$LOCATION_NAME
GBL[MAPSET]=$MAPSET
GBL[YYYYMMDD]=${GBL[MAPSET]%_s}
GBL[YYYY]=${MAPSET:0:4}
GBL[MM]=${MAPSET:4:2}
GBL[DD]=${GBL[YYYYMMDD]:6:2}

GBL[tz]=-8
GBL[constant_mapset]=500m
GBL[interpolate]="Tn Tx Tdew U2"
GBL[solar]="Rs K"
GBL[calc]="Rnl ETo"

# Get Options
if [ $GIS_FLAG_F -eq 1 ] ; then
  GBL[overwrite]='--overwrite'
else
  GBL[overwrite]=''
fi

G_verify_mapset

stats_make
g.message -v message="Calculating [Tn|Tx|Tdew|U2|Rs|K|Rnl|ETo]_[d|q]_diff ${GBL[MAPSET]}"
for m in ${GBL[interpolate]} ${GBL[solar]} ${GBL[calc]}; do
  diff $m
  stats_add $m
done

# Calculate new BVEto
if [[ ${GBL[mapset]} =~ 01$ ]] ; then
  g.message -v message="Calculating [Tn|Tx|Tdew|U2|Rs|K|Rnl|ETo]_[d|q]_rms ${GBL[MAPSET]}"
#  for m in ${GBL[interpolate]} ${GBL[solar]} ${GBL[calc]}; do
#    echo rmse28 $m
#  done
fi
